# ── Terraform ────────────────────────────────────────────────────────────────
**/.terraform/
*.tfstate
*.tfstate.backup
*.tfplan
*.tfplan.json
crash.log
crash.*.log
override.tf
override.tf.json
*_override.tf
*_override.tf.json
.terraformrc
terraform.rc

# Sensitive variable files — never commit secrets
*.tfvars
*.tfvars.json
!terraform/environments/dev/terraform.tfvars.example
!terraform/environments/prod/terraform.tfvars.example

# ── Kubernetes / Helm ────────────────────────────────────────────────────────
kubeconfig
kubeconfig.*
*.kubeconfig
# Helm rendered manifests (not source charts)
charts/
Chart.lock

# ── AWS ──────────────────────────────────────────────────────────────────────
.aws/
aws-exports.json

# ── OS / Editor ──────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini
*.swp
*.swo
*~
.idea/
.vscode/
*.iml

# ── Secrets / Credentials ────────────────────────────────────────────────────
*.pem
*.key
*.p12
*.pfx
.env
.env.*
!.env.example
secrets.yaml
secrets.yml

# ── Logs / Temp ──────────────────────────────────────────────────────────────
*.log
tmp/
temp/
